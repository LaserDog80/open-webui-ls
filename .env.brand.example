# LLM Philosopher Chat — rebrand env template
# Copy to .env and fill in real values. .env is gitignored.

# === BRANDING ===
WEBUI_NAME=LLM Philosopher Chat

# === API CONNECTION (OpenAI-compatible) ===
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me

# Multi-provider (semicolon-separated) — uncomment if needed:
# OPENAI_API_BASE_URLS=https://api.openai.com/v1;http://localhost:11434/v1
# OPENAI_API_KEYS=sk-your-openai-key;not-needed

# === SECURITY ===
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=replace-with-strong-random-string
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=user

# === DISABLE OLLAMA (OpenAI-compatible only) ===
ENABLE_OLLAMA_API=false

# === ONE-SHOT: force .env values to override DB-stored config ===
# Set true for a single restart, then remove.
# RESET_CONFIG_ON_START=true
